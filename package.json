{
	"name": "open-world-strava",
	"version": "1.0.0",
	"description": "Client-side MapLibre exploration map for Strava activities",
	"type": "module",
	"homepage": "openworld.jsinha.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/jai-sinha/open-world.git"
	},
	"bugs": {
		"url": "https://github.com/jai-sinha/open-world/issues"
	},
	"author": "Jai Sinha <me@jsinha.com>",
	"license": "MIT",
	"engines": {
		"bun": "^1.0.0"
	},
	"scripts": {
		"dev": "concurrently \"bun run --hot server/server.ts\" \"vite\"",
		"dev:server": "bun run --hot server/server.ts",
		"dev:client": "vite",
		"build": "vite build",
		"prod": "bun run server/server.ts --prod",
		"preview": "bun run server/server.ts --prod",
		"type-check": "tsc --noEmit",
		"check": "bun run scripts/check-setup.ts"
	},
	"dependencies": {
		"@mapbox/polyline": "^1.2.1",
		"@mapbox/vector-tile": "^1.3.1",
		"bootstrap": "^5.3.8",
		"idb": "^8.0.0",
		"maplibre-gl": "^4.1.2",
		"pbf": "^3.2.1",
		"pmtiles": "^3.0.5",
		"react": "^19.2.5",
		"react-bootstrap": "^2.10.10",
		"react-dom": "^19.2.5"
	},
	"devDependencies": {
		"@types/mapbox__polyline": "^1.0.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"bun-types": "^1.0.0",
		"concurrently": "^9.2.1",
		"typescript": "^5.3.3",
		"vite": "^8.0.8"
	},
	"keywords": [
		"strava",
		"maplibre",
		"exploration",
		"geospatial",
		"web-worker",
		"indexeddb",
		"privacy-first",
		"client-side",
		"webgl",
		"map",
		"visualization",
		"r2",
		"geojson",
		"vector-tiles"
	],
	"files": [
		"dist",
		"public",
		"README.md",
		"LICENSE"
	]
}
